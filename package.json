{
  "name": "sdt-booking-backend",
  "version": "1.0.0",
  "description": "SDT Booking Assistant",
  "scripts": {
    "start": "node -e \"var h=require('http'),s=require('https'),u=require('url'),A=process.env.ANTHROPIC_API_KEY,G=process.env.GOOGLE_MAPS_API_KEY,N=process.env.NOOKAL_API_KEY,P=process.env.PORT||8080;function c(r){r.setHeader('Access-Control-Allow-Origin','*');r.setHeader('Access-Control-Allow-Methods','GET,POST,OPTIONS');r.setHeader('Access-Control-Allow-Headers','Content-Type')}function p(q){return new Promise(function(a,b){var d=[];q.on('data',function(x){d.push(x)});q.on('end',function(){try{a(JSON.parse(Buffer.concat(d).toString()))}catch(e){a({})}});q.on('error',b)})}function f(m,o,t,e,b){return new Promise(function(a,r){var d=b?JSON.stringify(b):'';var op={hostname:o,path:t,method:m,headers:e||{}};if(d){op.headers['Content-Type']='application/json';op.headers['Content-Length']=Buffer.byteLength(d)}var q=s.request(op,function(rs){var ch=[];rs.on('data',function(x){ch.push(x)});rs.on('end',function(){try{a({status:rs.statusCode,body:JSON.parse(Buffer.concat(ch).toString())})}catch(e){a({status:rs.statusCode,body:{}})}})});q.on('error',r);if(d)q.write(d);q.end()})}h.createServer(function(q,r){c(r);if(q.method==='OPTIONS'){r.writeHead(204);r.end();return}var pg=u.parse(q.url,true);if(pg.pathname==='/health'){r.writeHead(200,{'Content-Type':'application/json'});r.end(JSON.stringify({status:'ok'}));return}if(pg.pathname==='/analyse'&&q.method==='POST'){p(q).then(function(b){var bases={Christian:'Montmorency VIC',Gabriel:'Croydon North VIC',Greg:'Kilsyth VIC',Jason:'Wandin North VIC',Marc:'Werribee VIC',Sherri:'Wandin North VIC',Yves:'Rye VIC'};var dt={};return Promise.all(Object.keys(bases).map(function(n){return f('GET','maps.googleapis.com','/maps/api/distancematrix/json?origins='+encodeURIComponent(b.clientAddress+', VIC, Australia')+'&destinations='+encodeURIComponent(bases[n]+', Australia')+'&mode=driving&key='+G,{},null).then(function(rs){try{var e=rs.body.rows[0].elements[0];if(e.status==='OK')dt[n]={duration:e.duration.text,distance:e.distance.text}}catch(e){}})})).then(function(){var t=new Date(),fr=t.toISOString().split('T')[0],to=new Date(t.getTime()+30*86400000).toISOString().split('T')[0];return f('GET','app.nookal.com','/api/v1/appointments?from='+fr+'&to='+to,{'X-API-Key':N},null)}).then(function(di){var pr='You are a scheduling assistant for SDT Melbourne. Recommend best instructor.\\n\\nINSTRUCTOR ROSTER:\\n'+JSON.stringify(b.instructors||[])+'\\n\\nDIARY:\\n'+JSON.stringify(di.body||{})+'\\n\\nDRIVE TIMES:\\n'+JSON.stringify(dt)+'\\n\\nBOOKING: Client '+b.clientName+' at '+b.clientAddress+' VIC. Service: '+b.serviceType+'. Mods: '+b.modifications+'. Availability: '+b.availability+'\\n\\nRULES: 1.MODS FIRST 2.ZONE 3.ROUTING no dead runs 4.Sherri no adaptive mods 5.Jason only LFA+spinner 6.Christians Tuesdays often Community OT Brunswick\\n\\nRespond: 1.RECOMMENDED INSTRUCTOR 2.ROUTING 3.TIME SLOT 4.BACKUPS 5.FLAGS 6.NOOKAL NOTE';return f('POST','api.anthropic.com','/v1/messages',{'x-api-key':A,'anthropic-version':'2023-06-01'},{model:'claude-sonnet-4-20250514',max_tokens:1500,messages:[{role:'user',content:pr}]})}).then(function(ai){var txt='';(ai.body.content||[]).forEach(function(x){if(x.type==='text')txt+=x.text});r.writeHead(200,{'Content-Type':'application/json'});r.end(JSON.stringify({success:true,recommendation:txt,driveTimes:dt}))}).catch(function(e){r.writeHead(500,{'Content-Type':'application/json'});r.end(JSON.stringify({success:false,error:e.message}))})};return}r.writeHead(404,{'Content-Type':'application/json'});r.end(JSON.stringify({error:'not found'}))}).listen(P,function(){console.log('SDT running on port '+P)})\"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
